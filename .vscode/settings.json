{
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "html.format.indentInnerHtml": true,
    "css.validate": true,
    "javascript.validate.enable": true,
    "liveServer.settings.port": 3000,
    "liveServer.settings.root": "/",
    "files.associations": {
        "*.html": "html",
        "*.css": "css",
        "*.js": "javascript"
    }
}
